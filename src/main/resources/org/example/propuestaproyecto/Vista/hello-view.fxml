<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER" fx:controller="controlador.ClienteController" xmlns:fx="http://javafx.com/fxml">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    
    <Label text="Gestión de Clientes" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
    
    <TextField fx:id="txtCedula" promptText="Cédula"/>
    <TextField fx:id="txtNombre" promptText="Nombre completo"/>
    <TextField fx:id="txtTelefono" promptText="Teléfono"/>
    <TextField fx:id="txtCorreo" promptText="Correo electrónico"/>
    
    <HBox spacing="10" alignment="CENTER">
        <Button text="Guardar" onAction="#guardar"/>
        <Button text="Limpiar" onAction="#limpiar"/>
    </HBox>
</VBox>
